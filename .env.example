# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# Agent (research agent; optional overrides)
AGENT_MODEL=o3-mini
AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=150000
AGENT_MAX_TURNS=30

# Run limits
MAX_TOKENS_PER_RUN=4096
MAX_DOLLARS_PER_RUN=0.10
MAX_LOOP_ITERATIONS=50

# Logging
LOG_LEVEL=INFO
TRACEBACK=true

# Tools (set to 1 to use mock implementations)
ADK_MOCK_TOOLS=0
